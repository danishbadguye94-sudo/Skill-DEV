const S=(()=>{
  let board,solution,fixed,userErrors,sel=-1,diff='easy',hints=5,moves=0,secs=0,timer=null,won=false,actx=null;
  const REMOVE={easy:36,medium:46,hard:54};
  const $=id=>document.getElementById(id);

  // Audio
  function tone(f,t='sine',d=.12,v=.15){
    try{
      if(!actx)actx=new(window.AudioContext||window.webkitAudioContext)();
      const o=actx.createOscillator(),g=actx.createGain();
      o.connect(g);g.connect(actx.destination);o.type=t;o.frequency.value=f;
      g.gain.setValueAtTime(v,actx.currentTime);g.gain.exponentialRampToValueAtTime(.001,actx.currentTime+d);
      o.start();o.stop(actx.currentTime+d);
    }catch(e){}
  }
  const playWin=()=>[523,659,784,1047].forEach((f,i)=>setTimeout(()=>tone(f,'sine',.3,.12),i*120));

  // Engine
  function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.random()*(i+1)|0;[a[i],a[j]]=[a[j],a[i]]}return a}
  function isValid(g,idx,n){
    const r=idx/9|0,c=idx%9,br=(r/3|0)*3,bc=(c/3|0)*3;
    for(let i=0;i<9;i++)if(g[r*9+i]===n||g[i*9+c]===n||g[(br+(i/3|0))*9+bc+(i%3)]===n)return false;
    return true;
  }
  function solve(g){
    const i=g.indexOf(0);if(i<0)return true;
    for(const n of shuffle([1,2,3,4,5,6,7,8,9]))if(isValid(g,i,n)){g[i]=n;if(solve(g))return true;g[i]=0}
    return false;
  }
  function countSols(g,lim=2){
    let c=0;
    (function bt(g){if(c>=lim)return;const i=g.indexOf(0);if(i<0){c++;return}for(let n=1;n<=9;n++)if(isValid(g,i,n)){g[i]=n;bt(g);g[i]=0}})([...g]);
    return c;
  }
  function gen(){
    solution=Array(81).fill(0);solve(solution);board=[...solution];fixed=Array(81).fill(true);
    let r=0;for(const i of shuffle([...Array(81).keys()])){
      if(r>=REMOVE[diff])break;const b=board[i];board[i]=0;fixed[i]=false;
      if(countSols(board)!==1){board[i]=b;fixed[i]=true}else r++;
    }
    userErrors=Array(81).fill(false);
  }

  // Timer
  const fmt=s=>`${(s/60|0).toString().padStart(2,'0')}:${(s%60).toString().padStart(2,'0')}`;
  function startTimer(){stopTimer();secs=0;tick();timer=setInterval(()=>{secs++;tick()},1000)}
  function stopTimer(){clearInterval(timer);timer=null}
  function tick(){const t=fmt(secs);$('timer').textContent=t;const m=$('timerMobile');if(m)m.textContent=t}

  // Render
  function renderGrid(){
    const g=$('sudokuGrid');g.innerHTML='';
    for(let i=0;i<81;i++){
      const c=document.createElement('div');
      c.className='sudoku-cell'+(fixed[i]?' fixed':'');
      c.dataset.idx=i;c.dataset.row=i/9|0;c.dataset.col=i%9;
      if(board[i])c.textContent=board[i];
      c.onclick=()=>pick(i);g.appendChild(c);
    }
  }
  function updateCell(i){
    const c=document.querySelector(`[data-idx="${i}"]`);if(!c)return;
    c.textContent=board[i]||'';c.classList.remove('error','user-input','hint-cell');
    if(!fixed[i]&&board[i])c.classList.add(userErrors[i]?'error':'user-input');
  }
  function highlight(si){
    const sr=si/9|0,sc=si%9,sbr=(sr/3|0)*3,sbc=(sc/3|0)*3,sv=board[si];
    document.querySelectorAll('.sudoku-cell').forEach((c,i)=>{
      c.classList.remove('selected','highlighted');
      const r=i/9|0,cc=i%9;
      if(i===si)c.classList.add('selected');
      else if(r===sr||cc===sc||((r/3|0)*3===sbr&&(cc/3|0)*3===sbc))c.classList.add('highlighted');
      if(sv&&board[i]===sv&&i!==si)c.classList.add('selected');
    });
  }
  function updateProgress(){
    const f=board.filter(v=>v).length,p=Math.round(f/81*100)+'%';
    $('progressBar').style.width=p;const m=$('progressBarMobile');if(m)m.style.width=p;
    $('progressText').textContent=`${f} / 81`;
  }
  function updateMoves(){$('moveCounter').textContent=moves;const m=$('movesMobile');if(m)m.textContent=moves}
  function renderHints(){$('hintsDisplay').innerHTML=[...Array(5)].map((_,i)=>`<div class="hint-dot${i>=hints?' used':''}"></div>`).join('')}
  function flash(el,cls){if(el){el.classList.add(cls);setTimeout(()=>el.classList.remove(cls),600)}}

  // Interactions
  function pick(i){if(!won){sel=i;highlight(i)}}
  function inputNumber(n){
    if(sel<0||fixed[sel]||won)return;
    tone(600,'sine',.08,.1);board[sel]=n;userErrors[sel]=solution[sel]!==n;moves++;
    updateCell(sel);updateMoves();updateProgress();highlight(sel);
    if(!userErrors[sel])flash(document.querySelector(`[data-idx="${sel}"]`),'correct-flash');
    else tone(180,'sawtooth',.25,.15);
    checkWin();saveGame();
  }
  function erase(){
    if(sel<0||fixed[sel]||won)return;
    board[sel]=0;userErrors[sel]=false;moves++;updateCell(sel);updateMoves();updateProgress();highlight(sel);saveGame();
  }
  function useHint(){
    if(!hints)return toast('No hints remaining!');
    if(sel<0)return toast('Select a cell first');
    if(fixed[sel])return toast('This cell is fixed');
    if(board[sel]===solution[sel]&&board[sel])return toast('Cell is already correct!');
    tone(880,'sine',.2,.1);setTimeout(()=>tone(1100,'sine',.2,.08),100);
    board[sel]=solution[sel];userErrors[sel]=false;hints--;
    flash(document.querySelector(`[data-idx="${sel}"]`),'hint-cell');
    updateCell(sel);updateProgress();renderHints();highlight(sel);checkWin();saveGame();
  }
  function checkSolution(){
    let err=false;
    board.forEach((v,i)=>{if(!fixed[i]&&v){userErrors[i]=v!==solution[i];if(userErrors[i])err=true;updateCell(i)}});
    if(err){tone(180,'sawtooth',.25,.15);toast('Some cells have errors!')}else toast('Looking good! No errors found ✓');
  }
  function autoSolve(){
    if(won)return;const o=$('solvingOverlay');o.classList.add('show');
    setTimeout(()=>{board=[...solution];fixed=Array(81).fill(true);userErrors=Array(81).fill(false);
      renderGrid();updateProgress();o.classList.remove('show');stopTimer();toast('Puzzle auto-solved!');saveGame()},600);
  }
  function checkWin(){
    if(board.every(v=>v)&&board.every((v,i)=>v===solution[i])&&!won){
      won=true;stopTimer();playWin();
      setTimeout(()=>{
        $('modalTime').textContent=fmt(secs);$('modalMoves').textContent=moves;$('modalHints').textContent=5-hints;
        $('winModal').classList.add('show');launchConfetti();saveBestTime();
      },400);
    }
  }
  function launchConfetti(){
    const C=['#00ffc8','#7b6fff','#f7c948','#ff4f6d','#4f8ef7'];
    for(let i=0;i<60;i++)setTimeout(()=>{
      const e=document.createElement('div');e.className='confetti-piece';
      e.style.cssText=`left:${Math.random()*100}vw;top:-20px;background:${C[Math.random()*5|0]};animation-duration:${2+Math.random()*2}s;animation-delay:${Math.random()*.5}s`;
      document.body.appendChild(e);setTimeout(()=>e.remove(),4000);
    },i*30);
  }
  function newGame(){
    $('winModal').classList.remove('show');won=false;moves=0;hints=5;sel=-1;
    gen();renderGrid();updateMoves();updateProgress();renderHints();startTimer();loadBestTime();saveGame();
    toast(`New ${diff} puzzle started!`);
  }
  function setDifficulty(d){
    diff=d;document.querySelectorAll('.diff-btn').forEach(b=>b.classList.toggle('active',b.dataset.diff===d));newGame();
  }
  function toggleTheme(){
    const h=document.documentElement,dark=h.getAttribute('data-theme')==='dark';
    h.setAttribute('data-theme',dark?'light':'dark');$('themeToggle').textContent=dark?'☀️':'🌙';
    localStorage.setItem('sp-theme',dark?'light':'dark');
  }
  function setColorTheme(t){
    document.documentElement.setAttribute('data-color-theme',t);
    document.querySelectorAll('.theme-dot').forEach(d=>d.classList.toggle('active',d.dataset.color===t));
    localStorage.setItem('sp-color-theme',t);
  }
  function saveGame(){localStorage.setItem('sp-save',JSON.stringify({board,fixed,solution,diff,moves,secs,hints}))}
  function loadGame(){
    try{
      const s=JSON.parse(localStorage.getItem('sp-save'));if(!s)return false;
      board=s.board;fixed=s.fixed;solution=s.solution;diff=s.diff||'easy';
      moves=s.moves||0;secs=s.secs||0;hints=s.hints??5;
      userErrors=Array(81).fill(false);board.forEach((v,i)=>{if(!fixed[i]&&v)userErrors[i]=v!==solution[i]});
      return true;
    }catch(e){return false}
  }
  function saveBestTime(){
    const k=`sp-best-${diff}`,p=+localStorage.getItem(k)||Infinity;
    if(secs<p){localStorage.setItem(k,secs);loadBestTime()}
  }
  function loadBestTime(){
    const b=+localStorage.getItem(`sp-best-${diff}`);
    $('bestTime').textContent=b?fmt(b):'—';$('bestDiff').textContent=b?diff.toUpperCase():'';
  }
  let toastT;
  function toast(msg){const t=$('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastT);toastT=setTimeout(()=>t.classList.remove('show'),2500)}
  function showStats(){const f=board.filter(v=>v).length,e=userErrors.filter(Boolean).length;toast(`Accuracy:${f?Math.round((f-e)/f*100):0}% · Filled:${f}/81 · Errors:${e}`)}

  document.addEventListener('DOMContentLoaded',()=>{
    // BG nums
    const L=$('bgLayer');
    for(let i=0;i<20;i++){const e=document.createElement('div');e.className='bg-num';e.textContent=(Math.random()*9|0)+1;
      e.style.left=Math.random()*100+'vw';e.style.setProperty('--rot',(Math.random()*40-20)+'deg');
      e.style.animationDuration=(15+Math.random()*20)+'s';e.style.animationDelay=-(Math.random()*30)+'s';L.appendChild(e)}
    // Numpad
    const np=$('numpad');
    for(let i=1;i<=9;i++){const b=document.createElement('button');b.className='num-btn';b.textContent=i;b.onclick=()=>inputNumber(i);np.appendChild(b)}
    const er=document.createElement('button');er.className='num-btn erase';er.textContent='⌫';er.onclick=erase;np.appendChild(er);
    // Theme restore
    const th=localStorage.getItem('sp-theme')||'dark';
    document.documentElement.setAttribute('data-theme',th);$('themeToggle').textContent=th==='dark'?'🌙':'☀️';
    setColorTheme(localStorage.getItem('sp-color-theme')||'neon');
    // Start
    if(!loadGame())gen();
    renderGrid();updateMoves();updateProgress();renderHints();
    document.querySelectorAll('.diff-btn').forEach(b=>b.classList.toggle('active',b.dataset.diff===diff));
    startTimer();loadBestTime();
    document.addEventListener('keydown',e=>{
      if(won)return;
      if(e.key>='1'&&e.key<='9'){inputNumber(+e.key);return}
      if(['Backspace','Delete','0'].includes(e.key)){erase();return}
      if(sel<0)return;
      const d={ArrowUp:-9,ArrowDown:9,ArrowLeft:-1,ArrowRight:1}[e.key];
      if(d!=null){e.preventDefault();const n=sel+d;if(n>=0&&n<81)pick(n)}
    });
    const chk=()=>$('mobileStats').style.display=window.innerWidth<=900?'block':'none';
    window.addEventListener('resize',chk);chk();
  });
  return{inputNumber,erase,useHint,checkSolution,autoSolve,newGame,setDifficulty,toggleTheme,setColorTheme,saveGame,showStats};
})();
