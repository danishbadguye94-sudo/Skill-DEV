<body>
<div id="root">
  <h1>Number Guessing Game</h1>
  <p class="sub">Pick a difficulty and start guessing!</p>

  <!-- START SCREEN -->
  <div id="start-screen" class="screen active">
    <p class="diff-label">Choose Difficulty</p>
    <div class="diff-cards">
      <div class="diff-card" id="card-easy" onclick="selectDiff('easy')">
        <div class="d-icon">🟢</div>
        <div class="d-name">Easy</div>
        <div class="d-range">1 – 50</div>
      </div>
      <div class="diff-card selected" id="card-medium" onclick="selectDiff('medium')">
        <div class="d-icon">🟡</div>
        <div class="d-name">Medium</div>
        <div class="d-range">1 – 100</div>
      </div>
      <div class="diff-card" id="card-hard" onclick="selectDiff('hard')">
        <div class="d-icon">🔴</div>
        <div class="d-name">Hard</div>
        <div class="d-range">1 – 500</div>
      </div>
    </div>
    <div class="info-row">
      <div class="info-box">
        <div class="i-label">Number Range</div>
        <div class="i-val" id="info-range">1 – 100</div>
      </div>
      <div class="info-box">
        <div class="i-label">High Score</div>
        <div class="i-val" id="info-hs">0</div>
      </div>
    </div>
    <button class="btn-primary" onclick="startGame()">▶ Start Game</button>
  </div>

  <!-- GAME SCREEN -->
  <div id="game-screen" class="screen">
    <div class="stats-row">
      <div class="stat"><div class="lbl">Score</div><div class="val" id="s-score">0</div></div>
      <div class="stat"><div class="lbl">Attempts</div><div class="val" id="s-tries">0</div></div>
      <div class="stat"><div class="lbl">Time</div><div class="val" id="s-time">60s</div></div>
      <div class="stat"><div class="lbl">Round</div><div class="val" id="s-round">1</div></div>
    </div>
    <p class="hint" id="g-hint">Guess a number between 1 and 100</p>
    <div class="input-row">
      <input type="number" id="guess-input" placeholder="Enter your guess..." />
      <button id="guess-btn" onclick="guess()">Guess</button>
    </div>
    <div class="feedback f-idle" id="feedback">
      <div class="msg">Make your first guess!</div>
    </div>
    <div class="chips" id="chips"></div>
    <div class="game-bottom">
      <div class="hs">High Score: <span id="s-hs">0</span></div>
      <button id="quit-btn" onclick="endGame(false)">✕ Quit</button>
    </div>
  </div>

  <!-- RESULT SCREEN -->
  <div id="result-screen" class="screen">
    <div class="result-icon" id="r-icon">🎉</div>
    <div class="result-title" id="r-title">Game Over!</div>
    <div class="result-sub" id="r-sub">Here's how you did</div>
    <div class="result-stats">
      <div class="rs-box"><div class="r-lbl">Score</div><div class="r-val" id="r-score">0</div></div>
      <div class="rs-box"><div class="r-lbl">Rounds</div><div class="r-val" id="r-rounds">0</div></div>
      <div class="rs-box"><div class="r-lbl">Best</div><div class="r-val" id="r-hs">0</div></div>
    </div>
    <div class="new-best" id="r-newbest" style="display:none">🏆 New High Score!</div>
    <div class="result-btns">
      <button class="btn-primary" onclick="playAgain()">▶ Play Again</button>
      <button class="btn-secondary" onclick="goHome()">↩ Change Difficulty</button>
    </div>
  </div>
</div>

<script>
  const MODES = { easy:{max:50,pts:10}, medium:{max:100,pts:20}, hard:{max:500,pts:50} };
  let diff='medium', target, score=0, tries=0, round=1, timeLeft=60, timer=null, active=false;

  const $=id=>document.getElementById(id);
  const getHs=()=>parseInt(localStorage.getItem('ngg_hs')||'0');
  const saveHs=v=>localStorage.setItem('ngg_hs',v);

  $('info-hs').textContent=getHs();
  $('s-hs').textContent=getHs();

  function show(id){
    ['start-screen','game-screen','result-screen'].forEach(s=>$(s).classList.remove('active'));
    $(id).classList.add('active');
  }

  function selectDiff(d){
    diff=d;
    ['easy','medium','hard'].forEach(x=>$('card-'+x).classList.remove('selected'));
    $('card-'+d).classList.add('selected');
    $('info-range').textContent='1 – '+MODES[d].max;
  }

  function startGame(){ score=0; round=1; show('game-screen'); newRound(); }

  function newRound(){
    const cfg=MODES[diff];
    target=Math.floor(Math.random()*cfg.max)+1;
    tries=0; timeLeft=60; active=true;
    $('s-score').textContent=score;
    $('s-tries').textContent=0;
    $('s-round').textContent=round;
    $('g-hint').textContent=`Guess a number between 1 and ${cfg.max}`;
    $('chips').innerHTML='';
    $('guess-input').value='';
    $('guess-input').disabled=false;
    $('guess-btn').disabled=false;
    setFeedback('idle','Make your first guess!','');
    updateTimer();
    clearInterval(timer);
    timer=setInterval(()=>{ timeLeft--; updateTimer(); if(timeLeft<=0) endGame(true); },1000);
    $('guess-input').focus();
  }

  function updateTimer(){
    const el=$('s-time');
    el.textContent=timeLeft+'s';
    el.className='val'+(timeLeft<=10?' warn':'');
  }

  function setFeedback(type,msg,hint){
    const box=$('feedback');
    box.className='feedback f-'+type;
    box.innerHTML=`<div class="msg">${msg}</div>${hint?`<div class="hint2">${hint}</div>`:''}`;
    box.classList.add('pop');
    setTimeout(()=>box.classList.remove('pop'),300);
  }

  function playTone(freq,dur,type='sine'){
    try{
      const ctx=new(window.AudioContext||window.webkitAudioContext)();
      const o=ctx.createOscillator(),g=ctx.createGain();
      o.connect(g);g.connect(ctx.destination);
      o.type=type; o.frequency.value=freq;
      g.gain.setValueAtTime(0.15,ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+dur);
      o.start(); o.stop(ctx.currentTime+dur);
    }catch(e){}
  }

  function addChip(val,kind){
    const c=document.createElement('span');
    c.className=`chip c-${kind}`;
    c.textContent=val;
    $('chips').appendChild(c);
  }

  function guess(){
    if(!active) return;
    const cfg=MODES[diff];
    const g=parseInt($('guess-input').value);
    if(isNaN(g)||g<1||g>cfg.max){ setFeedback('high',`Please enter a number between 1 and ${cfg.max}`,''); return; }
    tries++;
    $('s-tries').textContent=tries;
    $('guess-input').value='';

    if(g===target){
      const pts=cfg.pts+Math.max(1,timeLeft);
      score+=pts;
      $('s-score').textContent=score;
      if(score>getHs()){ saveHs(score); $('s-hs').textContent=score; }
      addChip(g,'win');
      setFeedback('win',`🎉 Correct! The number was ${target}`,`+${pts} pts • ${tries} attempt${tries>1?'s':''}`);
      playTone(880,.35); setTimeout(()=>playTone(1100,.3),140); setTimeout(()=>playTone(1320,.4),260);
      active=false;
      setTimeout(()=>{ round++; newRound(); },1800);
    } else if(g<target){
      addChip(g,'low');
      setFeedback('low','⬆ Too Low!',`${g} is below the number`);
      playTone(300,.2,'triangle');
    } else {
      addChip(g,'high');
      setFeedback('high','⬇ Too High!',`${g} is above the number`);
      playTone(200,.2,'sawtooth');
    }
    $('guess-input').focus();
  }

  function endGame(timeout){
    active=false; clearInterval(timer);
    $('guess-input').disabled=true;
    $('guess-btn').disabled=true;

    const prevHs=getHs();
    const isNewBest=score>prevHs;
    if(isNewBest) saveHs(score);
    const finalHs=getHs();

    if(timeout){
      $('r-icon').textContent='⏰';
      $('r-title').textContent="Time's Up!";
      $('r-sub').textContent=`The number was ${target}`;
      playTone(150,.6,'sawtooth');
    } else {
      $('r-icon').textContent='👋';
      $('r-title').textContent='Game Ended';
      $('r-sub').textContent='You quit the game';
    }

    $('r-score').textContent=score;
    $('r-rounds').textContent=Math.max(0, round-1);
    $('r-hs').textContent=finalHs;
    $('r-newbest').style.display=isNewBest?'block':'none';
    $('info-hs').textContent=finalHs;
    $('s-hs').textContent=finalHs;

    setTimeout(()=>show('result-screen'), timeout?1200:0);
  }

  function playAgain(){ score=0; round=1; show('game-screen'); newRound(); }

  function goHome(){ $('info-hs').textContent=getHs(); show('start-screen'); }

  $('guess-input').addEventListener('keydown',e=>{ if(e.key==='Enter') guess(); });
</script>
</body>
</html>

